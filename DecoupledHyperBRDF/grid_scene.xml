
    <scene version="3.0.0">
        <integrator type="path">
            <integer name="max_depth" value="5"/>
        </integrator>
        
        <sensor type="perspective">
            <float name="fov" value="45"/>
            <transform name="to_world">
                <lookat origin="6.25, 0.0, 28.75" 
                        target="6.25, 0.0, 0" 
                        up="0, 1, 0"/>
            </transform>
            <film type="hdrfilm">
                <integer name="width" value="1920"/>
                <integer name="height" value="1080"/>
                <string name="pixel_format" value="rgb"/>
            </film>
        </sensor>
        
        <!-- 环境光：提供均匀照明 -->
        <emitter type="constant">
            <rgb name="radiance" value="0.8"/>
        </emitter>
        
        <!-- 主光源：产生高光和阴影 -->
        <emitter type="point">
            <point name="position" value="16.25, 10.0, 20"/>
            <rgb name="intensity" value="100.0"/>
        </emitter>
        
        <!-- 地面背景 -->
        <shape type="rectangle">
            <transform name="to_world">
                <scale x="100" y="100" z="1"/>
                <translate z="-1"/> 
            </transform>
            <bsdf type="diffuse">
                <rgb name="reflectance" value="0.2, 0.2, 0.2"/>
            </bsdf>
        </shape>
    
        <shape type="sphere">
            <transform name="to_world">
                <translate x="0.0" y="0.0" z="0"/>
            </transform>
            
            <!-- 这里使用 diffuse 作为占位，因为我们还没有完整的 NeuralBSDF 实现 -->
            <!-- 实际使用时，这里应该替换为 <bsdf type="neural_bsdf"> ... </bsdf> -->
            <bsdf type="diffuse">
                <!-- 使用不同颜色区分 -->
                <rgb name="reflectance" value="0.0, 0.0, 0.0"/>
            </bsdf>
        </shape>
        </scene>